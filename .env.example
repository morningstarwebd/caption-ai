# ─── Caption AI — Environment Variables ───

# Required: Groq API key for Whisper transcription & LLM refinement
# Get yours free at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: Path to FFmpeg executable (for video rendering/export)
# Download from https://ffmpeg.org/download.html
FFMPEG_PATH=C:/ffmpeg/bin/ffmpeg.exe

# Optional: Server configuration
PORT=8000
HOST=127.0.0.1
